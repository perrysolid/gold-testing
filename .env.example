# ── auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-32-chars-min-please-set-this
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
OTP_DEV_BYPASS=123456

# ── gemini ────────────────────────────────────────────────────────────────────
# Get key from https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Set to "true" to use stub responses (no API calls in tests)
GEMINI_MOCK=false

# ── gold price ────────────────────────────────────────────────────────────────
GOLD_API_PROVIDER=mock          # goldapi | metalpriceapi | mock
GOLDAPI_KEY=
METALPRICEAPI_KEY=
GOLD_PRICE_CACHE_TTL_SECONDS=900
GOLD_PRICE_MOCK_INR_PER_G_22K=6900

# ── ltv (RBI 2025 tiers) ──────────────────────────────────────────────────────
LTV_SMALL_TICKET_MAX_INR=250000
LTV_SMALL_TICKET=0.85
LTV_DEFAULT=0.75

# ── storage ───────────────────────────────────────────────────────────────────
OBJECT_STORE=local              # local | minio | s3
LOCAL_STORAGE_PATH=./data/artifacts
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=aurum-assets

# ── database ──────────────────────────────────────────────────────────────────
DB_URL=sqlite+aiosqlite:///./data/aurum.db
# For postgres: postgresql+asyncpg://user:pass@postgres:5432/aurum

# ── telemetry ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
METRICS_ENABLED=true

# ── demo ──────────────────────────────────────────────────────────────────────
DEMO_LENDER_MODE=true

# ── model paths (relative to backend/) ───────────────────────────────────────
JEWELRY_CLS_MODEL=models/jewelry_cls_yolov8n.pt
HALLMARK_DETECTOR_MODEL=models/hallmark_yolov8n.pt
SAM2_CONFIG=models/sam2_hiera_tiny.yaml
SAM2_CHECKPOINT=models/sam2_hiera_tiny.pt
MIDAS_MODEL_TYPE=MiDaS_small
WEIGHT_MODEL=models/weight_lgbm.pkl
PURITY_MODEL=models/purity_rf.pkl
AUDIO_CLASSIFIER_MODEL=models/audio_cls.pkl
CLIP_MODEL=openai/clip-vit-base-patch32
